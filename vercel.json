{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/**",
          "node_modules/sqlite3/**"
        ]
      }
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/web/?",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(app\\.js|style\\.css)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(manifest\\.webmanifest|sw\\.js)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/views/(.*)",
      "dest": "/frontend/views/$1"
    },
    {
      "src": "/$",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ]
}
