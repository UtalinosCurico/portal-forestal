PORT=4000
NODE_ENV=development
# Canonico para usuarios/auth. Si no se define, se usa SQLite local.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portal_forestal
PGSSLMODE=disable
JWT_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DEFAULT_ADMIN_NAME=Administrador Forestal
DEFAULT_ADMIN_EMAIL=admin@forestal.cl
DEFAULT_ADMIN_PASSWORD=Admin123!
CORS_ORIGIN=http://localhost:4000
