{
  "name": "portal-forestal-backend",
  "version": "1.0.0",
  "description": "Backend API para Portal Forestal Maule Norte",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "migrate": "node database/migrate.js",
    "seed": "node database/seed.js",
    "dedupe:preview": "node scripts/dedupe-solicitudes.js",
    "dedupe:apply": "node scripts/dedupe-solicitudes.js --apply",
    "dedupe:progressive:preview": "node scripts/dedupe-progressive-solicitudes.js",
    "dedupe:progressive:apply": "node scripts/dedupe-progressive-solicitudes.js --apply",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "sqlite3": "^5.1.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
